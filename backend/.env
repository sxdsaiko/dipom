# ─── Server ───────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=1234567890
DB_NAME=wanderlog

# ─── JWT ──────────────────────────────────────
JWT_SECRET=change_me_super_secret_key_32chars_min
JWT_EXPIRES=7d
JWT_REFRESH_EXPIRES=30d

# ─── Email (SMTP) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM="WanderLog <no-reply@wanderlog.app>"

# ─── Cloudinary ───────────────────────────────
CLOUDINARY_CLOUD=your_cloud
CLOUDINARY_KEY=your_key
CLOUDINARY_SECRET=your_secret

# ─── App ──────────────────────────────────────
APP_NAME=WanderLog
MAX_FILE_SIZE=10485760
SALT_ROUNDS=12
